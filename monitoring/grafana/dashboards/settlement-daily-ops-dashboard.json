{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Daily Step Last Duration (Completed)",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "max_over_time(spring_batch_step_seconds_max{spring_batch_step_name=\"dailySettlementStep\",spring_batch_step_status=\"COMPLETED\"}[30d])"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "none", "justifyMode": "auto" }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Daily Step Failures (24h)",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "increase(spring_batch_step_seconds_count{spring_batch_step_name=\"dailySettlementStep\",spring_batch_step_status=\"FAILED\"}[24h])"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "none", "justifyMode": "auto" }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "HTTP 5xx Rate (settlement-service)",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"settlement-service\",status=~\"5..\"}[5m]))"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "none", "justifyMode": "auto" }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Active DB Connections",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(hikaricp_connections_active{application=\"settlement-service\"})"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "none", "justifyMode": "auto" }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Daily Step Duration Trend",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "refId": "A",
          "expr": "spring_batch_step_seconds_max{spring_batch_step_name=\"dailySettlementStep\",spring_batch_step_status=\"COMPLETED\"}",
          "legendFormat": "completed"
        },
        {
          "refId": "B",
          "expr": "spring_batch_step_seconds_max{spring_batch_step_name=\"dailySettlementStep\",spring_batch_step_status=\"FAILED\"}",
          "legendFormat": "failed"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "single", "sort": "none" } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Daily Runs by Status (24h increase)",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "refId": "A",
          "expr": "increase(spring_batch_step_seconds_count{spring_batch_step_name=\"dailySettlementStep\",spring_batch_step_status=\"COMPLETED\"}[24h])",
          "legendFormat": "completed"
        },
        {
          "refId": "B",
          "expr": "increase(spring_batch_step_seconds_count{spring_batch_step_name=\"dailySettlementStep\",spring_batch_step_status=\"FAILED\"}[24h])",
          "legendFormat": "failed"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "single", "sort": "none" } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "JVM Heap Usage (%)",
      "datasource": "Prometheus",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum(jvm_memory_used_bytes{application=\"settlement-service\",area=\"heap\"}) / sum(jvm_memory_max_bytes{application=\"settlement-service\",area=\"heap\"})",
          "legendFormat": "heap%"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "single", "sort": "none" } }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "HTTP Request Rate (2xx/4xx/5xx)",
      "datasource": "Prometheus",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"settlement-service\",status=~\"2..\"}[5m]))",
          "legendFormat": "2xx"
        },
        {
          "refId": "B",
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"settlement-service\",status=~\"4..\"}[5m]))",
          "legendFormat": "4xx"
        },
        {
          "refId": "C",
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"settlement-service\",status=~\"5..\"}[5m]))",
          "legendFormat": "5xx"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "single", "sort": "none" } }
    }
  ],
  "refresh": "30s",

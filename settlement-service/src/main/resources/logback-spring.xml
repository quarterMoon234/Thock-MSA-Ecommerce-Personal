<?xml version="1.0" encoding="UTF-8"?>
<configuration scan="true" scanPeriod="30 seconds">

    <property name="LOG_PATH" value="${LOG_PATH:-./logs/settlement}"/>

    <include resource="logback-base.xml"/>

    <!-- API Logger -->
    <logger name="com.thock.back.settlement.reconciliation.in.controller.PgDataController" level="INFO" additivity="false">
        <appender-ref ref="API_FILE"/>
        <appender-ref ref="CONSOLE"/>
    </logger>

    <logger name="com.thock.back.settlement.reconciliation.in.controller.OrderItemDataController" level="INFO" additivity="false">
        <appender-ref ref="API_FILE"/>
        <appender-ref ref="CONSOLE"/>
    </logger>

    <logger name="com.thock.back.settlement.reconciliation.app.UseCase" level="INFO" additivity="false">
        <appender-ref ref="RECONCILIATION_FILE"/>
        <appender-ref ref="CONSOLE"/>
    </logger>


    <!-- Root Logger -->
    <root level="INFO">
        <appender-ref ref="APP_FILE"/>
        <appender-ref ref="CONSOLE"/>
    </root>

</configuration>